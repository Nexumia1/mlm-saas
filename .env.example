# ============================================================
# MLM SaaS Platform — Variables de Entorno
# Copia este archivo como .env y completa los valores
# ============================================================

# ─── APLICACIÓN ─────────────────────────────────────────────
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000

# ─── BASE DE DATOS ────────────────────────────────────────────
POSTGRES_USER=mlm_user
POSTGRES_PASSWORD=CAMBIA_ESTO_EN_PRODUCCION
POSTGRES_DB=mlm_saas
DATABASE_URL=postgresql://mlm_user:CAMBIA_ESTO_EN_PRODUCCION@localhost:5432/mlm_saas

# ─── REDIS ────────────────────────────────────────────────────
REDIS_PASSWORD=CAMBIA_ESTO_EN_PRODUCCION
REDIS_URL=redis://:CAMBIA_ESTO_EN_PRODUCCION@localhost:6379

# ─── MONGODB ──────────────────────────────────────────────────
MONGO_USER=mlm_mongo
MONGO_PASSWORD=CAMBIA_ESTO_EN_PRODUCCION
MONGODB_URL=mongodb://mlm_mongo:CAMBIA_ESTO_EN_PRODUCCION@localhost:27017/mlm_logs

# ─── JWT AUTH ─────────────────────────────────────────────────
# IMPORTANTE: Genera claves seguras con: openssl rand -base64 64
JWT_SECRET=GENERA_UNA_CLAVE_SEGURA_CON_OPENSSL
JWT_REFRESH_SECRET=GENERA_OTRA_CLAVE_SEGURA_DIFERENTE
JWT_EXPIRES_IN=15m

# ─── META / FACEBOOK ADS ──────────────────────────────────────
META_APP_ID=tu_app_id_de_meta
META_APP_SECRET=tu_app_secret_de_meta
META_ACCESS_TOKEN=tu_token_de_acceso

# ─── WHATSAPP BUSINESS API ────────────────────────────────────
WHATSAPP_WEBHOOK_TOKEN=token_secreto_para_verificacion_webhook
# Los tokens de cada número se guardan por tenant en la DB (encriptados)

# ─── TIKTOK ADS ───────────────────────────────────────────────
TIKTOK_APP_ID=tu_app_id_tiktok
TIKTOK_APP_SECRET=tu_app_secret_tiktok

# ─── OPENAI (IA integrada) ────────────────────────────────────
OPENAI_API_KEY=sk-...tu_api_key_de_openai

# ─── AWS S3 / CLOUDFLARE R2 (almacenamiento de medios) ────────
AWS_ACCESS_KEY_ID=tu_access_key
AWS_SECRET_ACCESS_KEY=tu_secret_key
AWS_REGION=us-east-1
AWS_BUCKET_NAME=mlm-saas-media

# ─── STRIPE (pagos y suscripciones) ───────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_BUSINESS=price_...

# ─── SENDGRID (emails) ────────────────────────────────────────
SENDGRID_API_KEY=SG...
EMAIL_FROM=noreply@tudominio.com
EMAIL_FROM_NAME=MLM SaaS Platform

# ─── NEXT.JS (frontend) ───────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_APP_NAME=MLM SaaS Platform
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
